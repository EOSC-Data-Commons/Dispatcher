from pydantic_settings import BaseSettings

class Settings(BaseSettings):
    egi_checkin_env: str = "{{ api.environment }}"
    client_id: str = "{{ oauth2.client_id }}"
    client_secret: str = "{{ oauth2.client_secret }}"
    redirect_uri: str = "https://{{ inventory_hostname }}/docs"
    cert_chain_file: str = "{{ nginx.cert }}/fullchain.pem"
    private_key_file: str = "{{ nginx.cert }}/privkey.pem"
    host: str = "{{ inventory_hostname }}"
    git_repos: str = "{{ git.repos }}"
    git_url_prefix: str = "{{ git.url_prefix }}"
    im_endpoint: str = "{{ im.endpoint }}"
    im_cloud_provider: dict = {{ im.cloud_provider }}
    im_max_time: int = {{ im.wait.max_time }}
    im_sleep: int = {{ im.wait.sleep }}
    im_max_retries: int = {{ im.wait.max_retries }}

    redis_port: int = {{ redis.port }}

    rancher_mode: str = "{{ kubernetes.mode | default('local') }}"

{% if kubernetes.mode == 'dev' %}
    rancher_dev_url: str = "{{ kubernetes.dev.url }}"
    rancher_dev_token_exchange_url: str = "{{ kubernetes.dev.token_exchange_url }}"
    rancher_dev_client_id: str = "{{ kubernetes.dev.client_id }}"
    rancher_dev_client_secret: str = "{{ kubernetes.dev.client_secret }}"
    rancher_dev_audience: str = "{{ kubernetes.dev.audience }}"
{% else %}
    rancher_dev_url: str = ""
    rancher_dev_token_exchange_url: str = ""
    rancher_dev_client_id: str = ""
    rancher_dev_client_secret: str = ""
    rancher_dev_audience: str = ""
{% endif %}

    log_level: str = "{{ logging.level | default('INFO') }}"
    log_format: str = "{{ logging.format | default('text') }}"

settings = Settings()